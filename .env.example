# At least 32 characters. Example: openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
# Session cookie: max age (seconds), Secure flag (true in production HTTPS), SameSite (lax|strict|none)
SESSION_MAX_AGE_SECONDS=28800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
# legacy = AUTH_PASSWORD login; supabase = Supabase Auth email/password
WEB_AUTH_PROVIDER=legacy
APP_PASSWORD=change-me
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
AUTH_PASSWORD=change-me
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
